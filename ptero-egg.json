{
  "meta": {
    "version": "PTDL_v2"
  },
  "exported_at": "2026-03-01T00:00:00+07:00",
  "name": "Pterodactyl Panel Web + CF Tunnel (Hardened) - ChikoDoe",
  "author": "ChikoDoe",
  "description": "Pterodactyl Panel web-only dengan Cloudflare Tunnel, hardening, read-only FS support, dan tanpa Wings - Created by ChikoDoe",
  "features": null,
  "docker_images": {
    "ghcr.io/parkervcp/yolks:nginx_php-8.2": "Nginx + PHP 8.2 (Hardened)"
  },
  "file_denylist": [],
  "startup": "bash start.sh",
  "config": {
    "files": {},
    "startup": "{ \"done\": \"Pterodactyl Panel Web + CF Tunnel started - ChikoDoe\" }",
    "logs": {
      "custom": true,
      "location": "storage/logs/panel.log"
    },
    "stop": "exit"
  },
  "scripts": {
    "installation": {
      "script": "apk add --no-cache git curl unzip mariadb-client && cd /home/container && if [ ! -f artisan ]; then git clone https://github.com/pterodactyl/panel.git . && curl -sS https://getcomposer.org/installer | php && php composer.phar install --no-dev --optimize-autoloader && cp .env.example .env; fi && curl -fsSL https://raw.githubusercontent.com/ChikoDoe/pterodactyl-egg/main/start-hardened.sh -o start.sh && chmod +x start.sh",
      "container": "ghcr.io/parkervcp/yolks:nginx_php-8.2",
      "entrypoint": "bash"
    }
  },
  "variables": [
    {
      "name": "APP URL",
      "description": "URL lengkap aplikasi (contoh: https://panel.domain.com)",
      "env_variable": "APP_URL",
      "default_value": "http://localhost:8080",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|url"
    },
    {
      "name": "APP ENV",
      "description": "Laravel environment (production/local)",
      "env_variable": "APP_ENV",
      "default_value": "production",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|in:local,production"
    },
    {
      "name": "APP KEY",
      "description": "Laravel APP KEY (akan digenerate otomatis jika kosong)",
      "env_variable": "APP_KEY",
      "default_value": "",
      "user_viewable": false,
      "user_editable": false,
      "rules": "nullable|string"
    },
    {
      "name": "APP DEBUG",
      "description": "Debug mode (true/false) - Jangan true di production",
      "env_variable": "APP_DEBUG",
      "default_value": "false",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|in:true,false"
    },
    {
      "name": "DB HOST",
      "description": "Host database (gunakan host eksternal, jangan localhost)",
      "env_variable": "DB_HOST",
      "default_value": "127.0.0.1",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string"
    },
    {
      "name": "DB PORT",
      "description": "Port database (default: 3306 untuk MySQL)",
      "env_variable": "DB_PORT",
      "default_value": "3306",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|numeric|between:1,65535"
    },
    {
      "name": "DB DATABASE",
      "description": "Nama database",
      "env_variable": "DB_DATABASE",
      "default_value": "panel",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string"
    },
    {
      "name": "DB USERNAME",
      "description": "Username database",
      "env_variable": "DB_USERNAME",
      "default_value": "pterodactyl",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string"
    },
    {
      "name": "DB PASSWORD",
      "description": "Password database",
      "env_variable": "DB_PASSWORD",
      "default_value": "",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string"
    },
    {
      "name": "AUTO MIGRATE",
      "description": "Jalankan migration otomatis saat startup (true/false)",
      "env_variable": "AUTO_MIGRATE",
      "default_value": "false",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|in:true,false"
    },
    {
