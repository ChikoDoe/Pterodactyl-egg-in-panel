    },
    {
      "name": "PHP_MEMORY_LIMIT",
      "description": "Memory limit untuk PHP (contoh: 256M)",
      "env_variable": "PHP_MEMORY_LIMIT",
      "default_value": "256M",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string"
    },
    {
      "name": "MAX_UPLOAD_SIZE",
      "description": "Maximum upload file size (contoh: 100M)",
      "env_variable": "MAX_UPLOAD_SIZE",
