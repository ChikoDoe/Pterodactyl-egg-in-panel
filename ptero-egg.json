{
  "meta": {
    "version": "PTDL_v2"
  },
  "exported_at": "2026-03-01T00:00:00+07:00",
  "name": "Pterodactyl Panel Web + CF Tunnel (Hardened) - ChikoDoe",
  "author": "ChikoDoe",
  "description": "Pterodactyl Panel web-only dengan Cloudflare Tunnel, hardening, tanpa Wings",
  "features": null,
  "docker_images": {
    "Nginx + PHP 8.2 (Hardened)": "ghcr.io/parkervcp/yolks:nginx_php-8.2"
  },
  "file_denylist": [],
  "startup": "bash start.sh",
  "config": {
    "files": {},
    "startup": "{ \"done\": \"Panel started\" }",
    "logs": {},
    "stop": "exit"
  },
  "scripts": {
    "installation": {
      "script": "apk add --no-cache git curl unzip mariadb-client && cd /home/container && if [ ! -f artisan ]; then git clone https://github.com/pterodactyl/panel.git . && curl -sS https://getcomposer.org/installer | php && php composer.phar install --no-dev --optimize-autoloader && cp .env.example .env; fi && curl -fsSL https://raw.githubusercontent.com/ChikoDoe/pterodactyl-egg/main/start-hardened.sh -o start.sh && chmod +x start.sh",
      "container": "ghcr.io/parkervcp/yolks:nginx_php-8.2",
      "entrypoint": "bash"
    }
  },
  "variables": [
    {
      "name": "APP URL",
      "env_variable": "APP_URL",
      "default_value": "http://localhost:8080",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "APP ENV",
      "env_variable": "APP_ENV",
      "default_value": "production",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "APP DEBUG",
      "env_variable": "APP_DEBUG",
      "default_value": "false",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "DB HOST",
      "env_variable": "DB_HOST",
      "default_value": "127.0.0.1",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "DB PORT",
      "env_variable": "DB_PORT",
      "default_value": "3306",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "DB DATABASE",
      "env_variable": "DB_DATABASE",
      "default_value": "panel",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "DB USERNAME",
      "env_variable": "DB_USERNAME",
      "default_value": "pterodactyl",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "DB PASSWORD",
      "env_variable": "DB_PASSWORD",
      "default_value": "",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "AUTO MIGRATE",
      "env_variable": "AUTO_MIGRATE",
      "default_value": "false",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "CF_TUNNEL_ENABLED",
      "env_variable": "CF_TUNNEL_ENABLED",
      "default_value": "false",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "CF_TUNNEL_TOKEN",
      "env_variable": "CF_TUNNEL_TOKEN",
      "default_value": "",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable"
    },
    {
      "name": "WEB PORT",
      "env_variable": "WEB_PORT",
      "default_value": "8080",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    },
    {
      "name": "TIMEZONE",
      "env_variable": "TZ",
      "default_value": "Asia/Jakarta",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required"
    }
  ]
}
